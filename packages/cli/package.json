{
  "name": "@test-guardian/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "test-guardian": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts",
    "dev": "tsx src/index.tsx",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@test-guardian/shared": "workspace:*",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "meow": "^13.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "eslint": "^9.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
